# Run outputs (per-run findings, merged reports, proposed diffs)
outputs/*
!outputs/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.coverage
.coverage.*

# Disposable scipy venvs from the numeric-verifier carve-out (legacy)
/tmp/ground-review-*/

# Editor / OS cruft
.DS_Store
*.swp
.vscode/
.idea/

# Local agent / tool state (per-machine, never committed)
.claude/
.antigravitycli/

# Timestamped backup files (foo.bak-YYYYMMDD-HHMMSS)
*.bak-20*
