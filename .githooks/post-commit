#!/usr/bin/env bash
# cmr-gate post-commit shim → calls Python L1 audit。
# 必须 git-tracked(理由同 vela review-gate:未 tracked 时 checkout/clean
# 会令 hook 静默消失)。
set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
HOOK="$REPO_ROOT/scripts/cmr-gate/postcommit_audit.py"
if [ -x "$HOOK" ] || [ -r "$HOOK" ]; then
  python3 "$HOOK" || true   # audit 永不阻断
fi
exit 0
